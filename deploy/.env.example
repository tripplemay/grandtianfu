# 阅天府 deploy 环境模板 (共享生产主机模型, 入仓)。真 .env 不入仓, 权限 600。
# 用法 (VPS /opt/grandtianfu): cp .env.example .env && 填实际值 && chmod 600 .env

# --- GHCR 镜像 ---
GHCR_OWNER=tripplemay                 # ghcr.io/<owner>/grandtianfu/{api,web}
TAG=latest                            # CI 部署时由 deploy.sh 覆盖为 git sha

# --- GHCR 只读 pull 登录 (镜像若为私有则必填; 公开可留空) ---
GHCR_USER=tripplemay
GHCR_TOKEN=                           # PAT (read:packages) 或留空跳过登录

# --- 应用 ---
# 生产必须留空 = 可写 (红线); 置 1 会令 save-geometry 返 403, 并由 /api/health readonly 字段告警。
GEOM_READONLY=
HOUSE=D

# --- 数据 bind (宿主路径, 须 chown 10001 与容器 appuser 对齐) ---
# /opt/grandtianfu/data/projects   -> 容器 /data/projects (见 docker-compose.prod.yml)
# /opt/grandtianfu/data/artifacts  -> 容器 /data/artifacts (AI 产物, 持久+备份)
# /opt/grandtianfu/data/uploads    -> 容器 /data/uploads   (空房上传, PIPL 敏感, 可删除)
#   首次: mkdir -p /opt/grandtianfu/data/{artifacts,uploads} && chown -R 10001:10001 /opt/grandtianfu/data

# --- AI 图像 (Phase 5; 缺则 AI 休眠不影响主服务) ---
OPENAI_BASE_URL=                      # OpenAI 兼容 relay, 形如 https://host:port/v1
OPENAI_API_KEY=                       # relay key (sk-...); 仅本机, 勿入仓; 定期轮换
IMAGE_MODEL=gpt-image-2               # 图像编辑模型 (默认 gpt-image-2)
AI_MAX_IMAGES_PER_PROJECT=200         # 每项目累计生成上限 (预算护栏)
AI_DAILY_IMAGE_CAP=500                # 全局当日生成上限
HTTPS_PROXY=                          # VPS 到 relay 需代理时填 (直连可留空)

# --- fal.ai 几何锁定实拍 (路线A; 缺 FAL_KEY 则第7步回退 gpt-image-2 轴测软参考, 不影响主服务) ---
FAL_KEY=                              # fal.ai key (形如 id:secret); 仅本机勿入仓; 用后轮换
# FAL_INPAINT_MODEL=fal-ai/flux-general/inpainting   # 默认即可, 一般无需设
# FAL_POLL_INTERVAL_S=3               # 队列轮询间隔 (默认 3s)
# FAL_POLL_MAX=90                     # 轮询上限次数 (默认 90 = ~4.5min)
