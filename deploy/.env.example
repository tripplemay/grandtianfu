# 阅天府 deploy 环境模板 (入仓)。真 .env 不入仓, 权限 600。
# 用法: cp .env.example .env && 填实际值 && chmod 600 .env

# --- GHCR 镜像 ---
GHCR_OWNER=your-github-owner          # ghcr.io/<owner>/grandtianfu-{api,web}
TAG=latest                            # CI 部署时覆盖为 git sha

# --- 域名 / TLS ---
DOMAIN=studio.example.com
CERTBOT_EMAIL=you@example.com

# --- 数据 / 备份 ---
BACKUP_SRC=/srv/grandtianfu/data/projects
BACKUP_REMOTE=r2:grandtianfu-backup   # rclone remote:bucket (MVP 必需, 缺则 backup.sh 报错退出)

# --- 应用 ---
# 生产必须留空 = 可写 (红线); 置 1 会令 save-geometry 返 403。
GEOM_READONLY=
HOUSE=D
