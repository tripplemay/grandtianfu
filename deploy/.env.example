# 阅天府 deploy 环境模板 (共享生产主机模型, 入仓)。真 .env 不入仓, 权限 600。
# 用法 (VPS /opt/grandtianfu): cp .env.example .env && 填实际值 && chmod 600 .env

# --- GHCR 镜像 ---
GHCR_OWNER=tripplemay                 # ghcr.io/<owner>/grandtianfu/{api,web}
TAG=latest                            # CI 部署时由 deploy.sh 覆盖为 git sha

# --- GHCR 只读 pull 登录 (镜像若为私有则必填; 公开可留空) ---
GHCR_USER=tripplemay
GHCR_TOKEN=                           # PAT (read:packages) 或留空跳过登录

# --- 应用 ---
# 生产必须留空 = 可写 (红线); 置 1 会令 save-geometry 返 403, 并由 /api/health readonly 字段告警。
GEOM_READONLY=
HOUSE=D

# --- 数据 bind (宿主路径, 须 chown 10001 与容器 appuser 对齐) ---
# /opt/grandtianfu/data/projects -> 容器 /data/projects (见 docker-compose.prod.yml)
